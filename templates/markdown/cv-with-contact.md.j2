# {{ basics.name }} {: .cv-name }
{{ basics.label | replace("\n", "  \n") }}
{: .cv-label }

{{ basics.location.city }}{% if basics.email %} · {{ basics.email }}{% endif %}{% if basics.phone %} · {{ basics.phone }}{% endif %}{% if basics.url %} · {{ basics.url }}{% endif %} 
{: .cv-location }

## RÉSUMÉ {: .section-title }

{{ basics.summary | replace("\n", "<br><br>\n") }}
{: .summary }

## COMPÉTENCES {: .section-title }

<div class="skills-list">
{% for keyword in skills | map(attribute='keywords') | flatten %}
<span class="skill-pill">{{ keyword }}</span>
{% endfor %}
</div>

## EXPÉRIENCES {: .section-title }

{% for w in work %}
<div class="work-header">
  <h3 class="work-title">{{ w.name }}</h3>
  <p class="work-dates">{{ format_month(w.startDate) }} - {{ format_month(w.endDate) }}</p>
</div>

<div class="skills-list work-skills">
{% for keyword in w.skills %}
<span class="skill-pill">{{ keyword }}</span>
{% endfor %}
</div>

{{ w.summary | replace("\n", "<br><br>\n") }}
{: .work-summary }

{% if w.tasks %}
**Tâches :**
{: .work-tasks-title }

{% for task in w.tasks %}
- {{ task }}
{% endfor %}
{: .work-tasks }
{% endif %}

{% if w.recommendations %}
**Recommandations :**
{: .work-recommendations-title }

{% for recommendation in w.recommendations %}
> **{{ recommendation.name }}**{% if recommendation.position %} — {{ recommendation.position }}{% endif %}  
>
> {{ recommendation.text | replace("\n", "\n> ") }}

{% endfor %}
{% endif %}

{% if not loop.last %}
---
{% endif %}

{% endfor %}

## PROJETS {: .section-title }

{% for project in projects %}
### {{ project.name }} {: .project-title }

<div class="skills-list">
{% for keyword in project.skills %}
<span class="skill-pill">{{ keyword }}</span>
{% endfor %}
</div>

{{ project.description | replace("\n", "<br><br>\n") }}
{: .project-description }

{{ project.url }}
{: .project-url }

{% if not loop.last %}
---
{% endif %}

{% endfor %}

## FORMATION {: .section-title }

{% for e in education %}
<div class="education-item">
  <div class="education-header">
    <div>
      <p class="education-degree">{{ e.studyType }}</p>
      <h3 class="education-school">{{ e.institution }}</h3>
      <p class="education-area">{{ e.area }}</p>
    </div>
    <p class="education-date">{{ format_year(e.endDate) }}</p>
  </div>
</div>

{% if not loop.last %}
---
{% endif %}

{% endfor %}

## LANGUES {: .section-title }

<ul class="languages-list">
{% for language in languages %}
<li><strong>{{ language.language }}</strong> · {{ language.fluency }}</li>
{% endfor %}
</ul>
